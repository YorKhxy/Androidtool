{
  "name": "android-device-monitor",
  "version": "1.0.5",
  "description": "安卓设备监控 - 设备监控工具",
  "main": "./dist/main/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k -n main,renderer,electron \"npm run dev:main\" \"npm run dev:renderer\" \"node ./scripts/start-dev-electron.js\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:renderer": "webpack serve --mode development",
    "adb:prepare": "node ./scripts/prepare-platform-tools.js",
    "scrcpy:prepare": "node ./scripts/prepare-scrcpy.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && node ./scripts/copy-preload.js",
    "build:renderer": "webpack --mode production",
    "start": "electron .",
    "pack": "npm run adb:prepare && npm run scrcpy:prepare && electron-builder --dir",
    "dist": "npm run adb:prepare && npm run scrcpy:prepare && electron-builder",
    "serve:updates": "node ./scripts/serve-updates.js",
    "update:pack": "powershell -ExecutionPolicy Bypass -File ./scripts/make-update-package.ps1",
    "release": "powershell -ExecutionPolicy Bypass -File ./scripts/build-and-package.ps1",
    "release-bat": "scripts\\build-and-package.bat",
    "test": "jest"
  },
  "keywords": [
    "android",
    "adb",
    "monitor",
    "debug"
  ],
  "author": "Developer",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "concurrently": "^8.0.0",
    "css-loader": "^6.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "html-webpack-plugin": "^5.0.0",
    "jest": "^29.0.0",
    "style-loader": "^3.0.0",
    "tailwindcss": "^3.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^4.0.0"
  },
  "dependencies": {
    "adbkit": "^2.11.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.290.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "build": {
    "appId": "com.example.androiddevicemonitor",
    "productName": "安卓设备监控",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://192.168.1.158:8384/"
      }
    ],
    "releaseInfo": {
      "releaseNotesFile": "release-notes.md"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "index.html",
      "release-notes.md"
    ],
    "extraResources": [
      {
        "from": "vendor/platform-tools",
        "to": "platform-tools",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/scrcpy",
        "to": "scrcpy",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": "deb"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "\\\\node_modules\\\\",
      "\\\\dist\\\\",
      "\\\\src\\\\release\\\\"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/dist",
      "<rootDir>/src/release"
    ]
  }
}
